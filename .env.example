# --- Google Cloud Vision (OCR on /api/extract) ---
GOOGLE_CLOUD_VISION_API_KEY=

# --- Google Sheets (/api/save-expense) — OAuth2 only (no service account) ---
# 1. Google Cloud Console → APIs & Services → Enable "Google Sheets API".
# 2. Credentials → Create credentials → OAuth client ID → Application type: Web application.
# 3. Add Authorized redirect URIs (must match GOOGLE_REDIRECT_URI exactly), e.g.:
#    https://developers.google.com/oauthplayground/   (for OAuth Playground)
#    or your app callback URL if you build a custom consent flow.
# 4. Set the four variables below. Obtain GOOGLE_REFRESH_TOKEN once (one-time OAuth; see team docs).

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_REFRESH_TOKEN=

# Optional: defaults to the project spreadsheet if unset
GOOGLE_SHEETS_SPREADSHEET_ID=18mYAX0wScH9AVgn_EC_k_0YVGqiC-Z2CJwqXq8ifwR0
